#!/usr/bin/env bash
# ttd — Time-To-Date: days until a given date

set -euo pipefail

VERSION="0.1.0"

usage() {
  cat <<'EOF'
ttd — Time-To-Date

Usage:
  ttd MM-DD-YYYY    Days until the given date
  ttd -h            Show help
  ttd -v            Show version

Example:
  ttd 07-22-2026    # days until July 22, 2026
EOF
}

if [[ $# -eq 0 ]] || [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "-v" ]] || [[ "${1:-}" == "--version" ]]; then
  echo "ttd $VERSION"
  exit 0
fi

input=$1
if ! [[ "$input" =~ ^([0-9]{2})-([0-9]{2})-([0-9]{4})$ ]]; then
  echo "ttd: expected date as MM-DD-YYYY, got: $input" >&2
  exit 1
fi

month=${BASH_REMATCH[1]}
day=${BASH_REMATCH[2]}
year=${BASH_REMATCH[3]}
iso="${year}-${month}-${day}"

if ! target_epoch=$(date -d "$iso" +%s 2>/dev/null); then
  echo "ttd: invalid date: $input" >&2
  exit 1
fi

now_epoch=$(date +%s)
days=$(( (target_epoch - now_epoch) / 86400 ))

if date -d "$iso" +"%B %-d" &>/dev/null; then
  label=$(date -d "$iso" +"%B %-d")
else
  label=$(date -d "$iso" +"%B %d" | sed 's/ 0/ /')
fi

if (( days == 1 || days == -1 )); then
  unit=day
else
  unit=days
fi

if (( days < 0 )); then
  echo "$(( -days )) $unit ago ($label)"
elif (( days == 0 )); then
  echo "Today is $label"
else
  echo "$days $unit until $label"
fi